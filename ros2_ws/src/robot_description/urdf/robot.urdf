<?xml version="1.0"?>
<robot name="four_axis_robot">

<!-- ================= BASE ================= -->
<link name="base_link">
  <visual>
    <geometry>
      <cylinder radius="0.08" length="0.10"/>
    </geometry>
    <material name="gray">
      <color rgba="0.4 0.4 0.4 1"/>
    </material>
  </visual>
  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.10"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="10.0"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<!-- ================= LINK 1 ================= -->
<link name="shoulder_link">
  <visual>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
    <geometry>
      <box size="0.05 0.05 0.25"/>
    </geometry>
    <material name="red">
      <color rgba="1 0 0 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
    <geometry>
      <box size="0.05 0.05 0.25"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="10.0"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<!-- ================= LINK 2 ================= -->
<link name="bicep_link">
  <visual>
    <origin xyz="0.125 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.25 0.045 0.045"/>
    </geometry>
    <material name="green">
      <color rgba="0 1 0 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0.125 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.25 0.045 0.045"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="10.0"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<!-- ================= LINK 3 ================= -->
<link name="forearm_link">
  <visual>
    <origin xyz="0.125 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.25 0.040 0.040"/>
    </geometry>
    <material name="blue">
      <color rgba="0 0 1 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0.125 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.25 0.040 0.040"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="10.0"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<!-- ================= TOOL ================= -->
<link name="tool0">
  <visual>
    <origin xyz="0.075 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.15 0.03 0.03"/>
    </geometry>
    <material name="yellow">
      <color rgba="1 1 0 1"/>
    </material>
  </visual>
  <collision>
    <origin xyz="0.075 0 0" rpy="0 0 0"/>
    <geometry>
      <box size="0.15 0.03 0.03"/>
    </geometry>
  </collision>
  <inertial>
    <mass value="10.0"/>
    <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
  </inertial>
</link>

<!-- ================= TCP ================= -->
  <link name="tcp"/>
  <joint name="tcp_joint" type="fixed">
    <parent link="tool0"/>
    <child link="tcp"/>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
  </joint>
  <collision name="tcp_collision">
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.02"/>
    </geometry>
  </collision>
  <inertial name="tcp_inertial">
    <mass value="0.1"/>
    <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
  </inertial>

<!-- ================= JOINT1 ================= -->
  <joint name="base_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.125" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="100" velocity="1.0"/>
  </joint>

<!-- ================= JOINT2 ================= -->
  <joint name="shoulder_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="bicep_link"/>
    <origin xyz="0 0 0.250" rpy="0 -1.5708 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.094" upper="2.094" effort="100" velocity="1.0"/>
  </joint>

<!-- ================= JOINT3 ================= -->
  <joint name="elbow_joint" type="revolute">
    <parent link="bicep_link"/>
    <child link="forearm_link"/>
    <origin xyz="0.250 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="100" velocity="1.0"/>
  </joint>

<!-- ================= JOINT4 ================= -->
  <joint name="wrist_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="tool0"/>
    <origin xyz="0.250 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.571" upper="1.571" effort="100" velocity="1.0"/>
  </joint>

</robot>